APP_ENV=production
SECRET_KEY=replace-with-strong-secret

# Supabase PostgreSQL — session-mode pooler (port 5432)
DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

CORS_ORIGINS=https://dashboard.example.com
PUBLIC_BASE_URL=https://api.example.com
VET_CAN_VIEW_ALL=true
ML_SERVICE_URL=http://ml:8000
RUN_MIGRATIONS_ON_START=true
RUN_SEED_ON_START=false

# Supabase Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=case-images

# SMTP (required in production for OTP signup/password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app-specific-password
SMTP_FROM=noreply@cattle-ai.example.com
SMTP_TLS=true
