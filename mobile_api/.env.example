APP_ENV=development
# Set to true only during local browser testing; false in production
CORS_ALLOW_ALL=false
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ML inference service (set to http://localhost:8001 for local dev)
# INFERENCE_API_URL=http://localhost:8001
INFERENCE_ALLOW_RULES_FALLBACK=true
INFERENCE_STRICT_MODE=false

# Optional SMTP (OTP email delivery)
# If unset, OTP codes appear in the API response body (dev mode)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@gmail.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM=noreply@cattle.ai
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
