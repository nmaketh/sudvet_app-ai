[Unit]
Description=Cattle AI Mobile API (FastAPI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/cattle_disease_app/mobile_api
EnvironmentFile=/etc/cattle-ai/mobile_api.env
ExecStart=/opt/cattle_disease_app/mobile_api/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
