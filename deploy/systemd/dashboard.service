[Unit]
Description=Cattle AI Dashboard (Next.js)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/cattle_disease_app/dashboard
Environment=NODE_ENV=production
EnvironmentFile=/etc/cattle-ai/dashboard.env
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
