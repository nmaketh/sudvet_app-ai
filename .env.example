# Copy this file to .env and fill in real values before running docker-compose.
# The .env file is gitignored — never commit real secrets.

# ── ops_api JWT secret (use a long random string in production) ──────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OPS_SECRET_KEY=dev-only-change-before-deploying

# ── Supabase PostgreSQL (session-mode pooler, port 5432) ─────────────────────
# Find in: Supabase Dashboard → Project Settings → Database → Connection String → Session mode
DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Bucket name — create in Supabase Dashboard → Storage, set to Public
SUPABASE_STORAGE_BUCKET=case-images

# ── CORS ─────────────────────────────────────────────────────────────────────
# ops_api: comma-separated list of allowed dashboard origins
OPS_CORS_ORIGINS=http://localhost:3000
# mobile_api: set to true only during local dev when testing from a browser
MOBILE_CORS_ALLOW_ALL=false
# MOBILE_CORS_ORIGINS=http://localhost:8080

# ── SMTP (optional — enables OTP email delivery) ─────────────────────────────
# If unset, OTP codes are returned in the API response body (dev mode only)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=app-specific-password
# SMTP_FROM=noreply@cattle.ai

# ── App settings ─────────────────────────────────────────────────────────────
APP_ENV=production
# Token expiry in minutes (default 30)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# Set to true only to seed default test users (NEVER in production)
RUN_SEED_ON_START=false

# ── Google OAuth (optional — enables "Sign in with Google" on the mobile app) ─
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Create a "Web application" client ID; add your API domain to authorized origins.
# Leave empty to disable Google sign-in (email/password and OTP still work).
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Set to your ops_api public HTTPS URL in production
NEXT_PUBLIC_API_URL=https://your-api-domain.com
